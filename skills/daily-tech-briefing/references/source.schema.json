{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Daily Tech Briefing Source Registry",
  "type": "object",
  "required": ["version", "sources"],
  "properties": {
    "version": { "type": "string" },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "url", "category"],
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "type": { "type": "string", "enum": ["rss", "atom", "newsletter", "web", "manual"] },
          "category": { "type": "string", "enum": ["ai-labs", "developer-tools", "cloud-infra", "security-risk", "product-strategy", "creator-economy", "market-analysis", "editorial-analysis", "research", "company-news"] },
          "priority": { "type": "number", "minimum": 0, "maximum": 1 },
          "signals": { "type": "array", "items": { "type": "string" } },
          "rationale": { "type": "string" },
          "status": { "type": "string", "enum": ["default", "personal", "candidate", "muted", "archived"] },
          "language": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
